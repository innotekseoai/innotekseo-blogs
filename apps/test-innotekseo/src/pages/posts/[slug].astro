---
import { LocalAdapter } from "@innotekseo/blogs-core";
import PostLayout from "@innotekseo/blogs-components/PostLayout.astro";

const adapter = new LocalAdapter("./src/content/posts");

export async function getStaticPaths() {
  const adapter = new LocalAdapter("./src/content/posts");
  const posts = await adapter.getPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await adapter.getPost(slug!);
---

<PostLayout
  title={post.title}
  date={post.date}
  description={post.description}
  tags={post.tags}
  author="innotekseo-blogs"
  siteName="innotekseo-blogs Demo"
>
  <Fragment set:html={post.content} />
</PostLayout>
