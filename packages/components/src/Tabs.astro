---
interface Props {
  labels: string[];
}

const { labels } = Astro.props;
const id = `ib-tabs-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="ib-tabs" id={id}>
  <div class="ib-tabs-headers" role="tablist">
    {labels.map((label, i) => (
      <button
        role="tab"
        class={`ib-tab-btn ${i === 0 ? "active" : ""}`}
        aria-selected={i === 0 ? "true" : "false"}
        aria-controls={`${id}-panel-${i}`}
        id={`${id}-tab-${i}`}
        tabindex={i === 0 ? 0 : -1}
        data-tab-index={i}
      >
        {label}
      </button>
    ))}
  </div>
  <div class="ib-tabs-panels">
    {labels.map((_label, i) => (
      <div
        role="tabpanel"
        id={`${id}-panel-${i}`}
        aria-labelledby={`${id}-tab-${i}`}
        class="ib-tab-panel"
        hidden={i !== 0}
      />
    ))}
  </div>
  <div class="ib-tabs-slot" style="display:none;">
    <slot />
  </div>
</div>

<script define:vars={{ id, labelCount: labels.length }}>
  const root = document.getElementById(id);
  if (root) {
    const buttons = root.querySelectorAll("[role=tab]");
    const slotChildren = root.querySelector(".ib-tabs-slot")?.children;
    const panels = root.querySelectorAll("[role=tabpanel]");

    // Move slot children into panels
    if (slotChildren) {
      Array.from(slotChildren).forEach((child, i) => {
        if (panels[i]) panels[i].appendChild(child);
      });
    }

    function activateTab(index) {
      buttons.forEach((btn, i) => {
        const isActive = i === index;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-selected", String(isActive));
        btn.setAttribute("tabindex", isActive ? "0" : "-1");
      });

      panels.forEach((panel, i) => {
        panel.hidden = i !== index;
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        activateTab(Number(btn.dataset.tabIndex));
      });

      btn.addEventListener("keydown", (e) => {
        const current = Number(btn.dataset.tabIndex);
        let next = current;

        switch (e.key) {
          case "ArrowRight":
          case "ArrowDown":
            next = (current + 1) % labelCount;
            e.preventDefault();
            break;
          case "ArrowLeft":
          case "ArrowUp":
            next = (current - 1 + labelCount) % labelCount;
            e.preventDefault();
            break;
          case "Home":
            next = 0;
            e.preventDefault();
            break;
          case "End":
            next = labelCount - 1;
            e.preventDefault();
            break;
          default:
            return;
        }

        activateTab(next);
        buttons[next].focus();
      });
    });

    // Remove the slot wrapper
    const slotWrapper = root.querySelector(".ib-tabs-slot");
    if (slotWrapper) slotWrapper.remove();
  }
</script>

<style>
  .ib-tabs {
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .ib-tabs-headers {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .ib-tab-btn {
    padding: 0.5rem 1rem;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748b;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .ib-tab-btn:hover {
    color: #0f172a;
  }
  .ib-tab-btn:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: -2px;
  }
  .ib-tab-btn.active {
    color: #0f172a;
    border-bottom-color: #3b82f6;
  }
  .ib-tabs-panels {
    padding: 1rem;
  }
</style>
